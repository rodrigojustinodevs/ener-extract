# =============
# MySQL (Docker Compose)
# =============
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=ener_extract
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_PORT=3309

# =============
# App
# =============
APP_PORT=3001
NODE_ENV=development

# =============
# Prisma – DATABASE_URL
# Na sua máquina (migrate, start:dev): use localhost e porta 3309
# No Docker (app container): use mysql e porta 3306 (definido no docker-compose)
# =============
DATABASE_URL="mysql://app:app@localhost:3309/ener_extract"

# Prisma Migrate usa um shadow database; a URL deve incluir o nome do banco (MySQL exige).
# Crie o banco antes do primeiro migrate: mysql -e "CREATE DATABASE IF NOT EXISTS ener_extract_shadow;"
SHADOW_DATABASE_URL="mysql://root:root@localhost:3309/ener_extract_shadow"

# =============
# JWT (Auth)
# =============
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =============
# Faturas – extrator (pdf = pdf-parse + Cemig | llm = Gemini)
# =============
INVOICE_EXTRACTOR_MODE=pdf

# =============
# Gemini (usado quando INVOICE_EXTRACTOR_MODE=llm)
# =============
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_MS=30000
