# =============
# MySQL (Docker Compose)
# =============
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=ener_extract
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_PORT=3309

# =============
# App
# =============
APP_PORT=3001
NODE_ENV=development

# =============
# Prisma – use este formato quando a app rodar DENTRO do Docker (host = mysql)
# Para rodar a app no host (localhost), use: mysql://app:app@localhost:3309/ener_extract
# =============
DATABASE_URL="mysql://app:app@mysql:3306/ener_extract"
