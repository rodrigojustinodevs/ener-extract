# =============
# MySQL (Docker Compose)
# =============
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=ener_extract
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_PORT=3309

# =============
# App
# =============
APP_PORT=3001
NODE_ENV=development

# =============
# Prisma – DATABASE_URL
# Na sua máquina (migrate, start:dev): use localhost e porta 3309
# No Docker (app container): use mysql e porta 3306 (definido no docker-compose)
# =============
DATABASE_URL="mysql://app:app@localhost:3309/ener_extract"

# Prisma Migrate usa um shadow database; o usuário precisa ter CREATE DATABASE.
# Use root (ou deixe vazio e use "pnpm prisma db push" em vez de migrate dev).
SHADOW_DATABASE_URL="mysql://root:root@localhost:3309/"

# =============
# JWT (Auth)
# =============
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
